// ================================
// RKC ERP - Prisma Schema
// 30+ Models for Kindergarten/Academy ERP
// ================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================================
// ENUMS
// ========================================

enum ProgramType {
  KINDERGARTEN
  ACADEMY
  BOTH
}

enum StudentStatus {
  PENDING
  ACTIVE
  ON_LEAVE
  WITHDRAWN
}

enum ClassType {
  KINDERGARTEN
  ACADEMY
}

enum BillingStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceStatus {
  GENERATED
  SENT_INTERNAL
  DOWNLOADED
  VOIDED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CLOSED
}

enum InvitationStatus {
  INVITED
  ACCEPTED
  EXPIRED
  REVOKED
}

enum DiscountType {
  FIXED
  PERCENT
}

enum GuardianRelation {
  FATHER
  MOTHER
  GRANDFATHER
  GRANDMOTHER
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
  INVITATION_SENT
  BILLING_GENERATED
  INVOICE_GENERATED
  PAYMENT_COLLECTED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
}

// ========================================
// USERS & AUTHENTICATION
// ========================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  isActive      Boolean  @default(true) @map("is_active")
  locale        String   @default("en") // User language preference
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  roleId      String?       @map("role_id")
  role        Role?         @relation(fields: [roleId], references: [id])
  profile     StaffProfile?
  permissions UserPermission[]
  auditLogs   AuditLog[]
  teacherAssignments TeacherAssignment[]

  @@map("users")
}

model StaffProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  phone       String?
  position    String?
  department  String?
  joinDate    DateTime? @map("join_date")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
}

// ========================================
// ROLES & PERMISSIONS
// ========================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  group       String   // e.g., 'student', 'class', 'billing'
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  permissionId String   @map("permission_id")
  granted      Boolean  @default(true) // true = grant, false = deny (override)
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ========================================
// INVITATIONS
// ========================================

model Invitation {
  id          String           @id @default(uuid())
  email       String
  token       String           @unique
  roleId      String           @map("role_id")
  status      InvitationStatus @default(INVITED)
  invitedBy   String           @map("invited_by")
  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("invitations")
}

// ========================================
// AUDIT LOGS
// ========================================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?     @map("user_id")
  action      AuditAction
  entity      String      // e.g., 'student', 'billing'
  entityId    String?     @map("entity_id")
  details     Json?       // JSON details of what changed
  ipAddress   String?     @map("ip_address")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ========================================
// STUDENTS & GUARDIANS
// ========================================

model Student {
  id            String        @id @default(uuid())
  studentCode   String        @unique @map("student_code") // Auto-generated code
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  gender        Gender?
  dateOfBirth   DateTime?     @map("date_of_birth")
  programType   ProgramType   @map("program_type")
  status        StudentStatus @default(PENDING)
  enrollDate    DateTime?     @map("enroll_date")
  withdrawDate  DateTime?     @map("withdraw_date")
  note          String?

  // Health: Allergy
  hasAllergy          Boolean   @default(false) @map("has_allergy")
  allergyDescription  String?   @map("allergy_description")

  // Health: Dental checkup (mandatory twice a year)
  lastDentalCheckDate DateTime? @map("last_dental_check_date")
  nextDentalCheckDate DateTime? @map("next_dental_check_date")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  guardians       StudentGuardian[]
  statusHistories StudentStatusHistory[]
  classStudents   ClassStudent[]
  promotions      StudentPromotion[]
  billings        Billing[]
  receivables     Receivable[]
  dentalCheckups  DentalCheckup[]
  healthCheckups  HealthCheckup[]

  @@index([status])
  @@index([programType])
  @@map("students")
}

// ─── Dental Checkup (연 2회 고정) ───
model DentalCheckup {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  year        Int      // 검진 연도 (2026)
  round       Int      // 회차 (1 또는 2)
  checkDate   DateTime @map("check_date")
  result      String?  // 검진 결과 (양호/치료필요/치료완료 등)
  findings    String?  // 특이사항
  dentist     String?  // 검진 기관/의사
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, year, round])
  @@index([studentId])
  @@map("dental_checkups")
}

// ─── Health Checkup (기본 건강검진) ───
model HealthCheckup {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  checkDate   DateTime @map("check_date")
  // 신체 측정
  heightCm    Float?   @map("height_cm")    // 키 (cm)
  weightKg    Float?   @map("weight_kg")    // 몸무게 (kg)
  // 시력
  visionLeft  String?  @map("vision_left")  // 좌안 시력 (0.8, 1.0 등)
  visionRight String?  @map("vision_right") // 우안 시력
  // 기타
  bloodType   String?  @map("blood_type")   // 혈액형 (A, B, O, AB)
  findings    String?  // 특이사항/소견
  note        String?  // 추가 메모
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("health_checkups")
}

model Guardian {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  students StudentGuardian[]

  @@map("guardians")
}

model StudentGuardian {
  id         String           @id @default(uuid())
  studentId  String           @map("student_id")
  guardianId String           @map("guardian_id")
  relation   GuardianRelation
  isPrimary  Boolean          @default(false) @map("is_primary")
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@map("student_guardians")
}

model StudentStatusHistory {
  id          String        @id @default(uuid())
  studentId   String        @map("student_id")
  fromStatus  StudentStatus @map("from_status")
  toStatus    StudentStatus @map("to_status")
  reason      String?
  changedBy   String?       @map("changed_by") // user id
  changedAt   DateTime      @default(now()) @map("changed_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_status_histories")
}

// ========================================
// CLASSES & TEACHER ASSIGNMENTS
// ========================================

model Class {
  id          String    @id @default(uuid())
  name        String
  classType   ClassType @map("class_type")
  description String?
  capacity    Int       @default(20)
  isActive    Boolean   @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  students ClassStudent[]
  teachers TeacherAssignment[]

  @@map("classes")
}

model ClassStudent {
  id         String    @id @default(uuid())
  classId    String    @map("class_id")
  studentId  String    @map("student_id")
  enrolledAt DateTime  @default(now()) @map("enrolled_at")
  removedAt  DateTime? @map("removed_at")
  isActive   Boolean   @default(true) @map("is_active")

  // Relations
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_students")
}

model TeacherAssignment {
  id         String    @id @default(uuid())
  classId    String    @map("class_id")
  userId     String    @map("user_id") // Staff user as teacher
  isPrimary  Boolean   @default(false) @map("is_primary")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  removedAt  DateTime? @map("removed_at")
  isActive   Boolean   @default(true) @map("is_active")

  // Relations
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@map("teacher_assignments")
}

// ========================================
// STUDENT PROMOTIONS
// ========================================

model StudentPromotion {
  id              String       @id @default(uuid())
  studentId       String       @map("student_id")
  promotionName   String       @map("promotion_name")
  discountType    DiscountType @map("discount_type")
  discountValue   Float        @map("discount_value") // amount or percentage
  applicableItem  String?      @map("applicable_item") // billing template id or null for all
  startMonth      DateTime     @map("start_month") // YYYY-MM-01
  endMonth        DateTime     @map("end_month")   // YYYY-MM-01
  isActive        Boolean      @default(true) @map("is_active")
  note            String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([startMonth, endMonth])
  @@map("student_promotions")
}

// ========================================
// BILLING & INVOICES
// ========================================

model BillingTemplate {
  id          String      @id @default(uuid())
  name        String
  description String?
  amount      Float
  programType ProgramType @map("program_type") // Which program this applies to
  isActive    Boolean     @default(true) @map("is_active")
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("billing_templates")
}

model Billing {
  id              String        @id @default(uuid())
  studentId       String        @map("student_id")
  billingMonth    DateTime      @map("billing_month") // YYYY-MM-01
  subtotal        Float         // Before discount
  discountTotal   Float         @default(0) @map("discount_total")
  totalAmount     Float         @map("total_amount") // After discount
  paidAmount      Float         @default(0) @map("paid_amount")
  status          BillingStatus @default(DRAFT)
  dueDate         DateTime?     @map("due_date")
  issuedAt        DateTime?     @map("issued_at")
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  student    Student       @relation(fields: [studentId], references: [id])
  items      BillingItem[]
  invoice    Invoice?
  payments   Payment[]
  receivable Receivable?

  @@unique([studentId, billingMonth])
  @@index([status])
  @@index([billingMonth])
  @@map("billings")
}

model BillingItem {
  id              String  @id @default(uuid())
  billingId       String  @map("billing_id")
  itemName        String  @map("item_name")
  originalAmount  Float   @map("original_amount")
  discountAmount  Float   @default(0) @map("discount_amount")
  finalAmount     Float   @map("final_amount")
  promotionId     String? @map("promotion_id") // Reference to applied promotion
  promotionName   String? @map("promotion_name")

  // Relations
  billing Billing @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@map("billing_items")
}

model Invoice {
  id           String        @id @default(uuid())
  billingId    String        @unique @map("billing_id")
  invoiceNo    String        @unique @map("invoice_no") // Auto-generated
  status       InvoiceStatus @default(GENERATED)
  issuedAt     DateTime      @default(now()) @map("issued_at")
  downloadedAt DateTime?     @map("downloaded_at")
  voidedAt     DateTime?     @map("voided_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  billing Billing @relation(fields: [billingId], references: [id])

  @@index([status])
  @@map("invoices")
}

// ========================================
// PAYMENTS & RECEIVABLES
// ========================================

model Payment {
  id            String        @id @default(uuid())
  billingId     String        @map("billing_id")
  amount        Float
  paymentMethod PaymentMethod @map("payment_method")
  paymentDate   DateTime      @map("payment_date")
  reference     String?       // Transaction reference
  note          String?
  collectedBy   String?       @map("collected_by") // user id
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  billing Billing @relation(fields: [billingId], references: [id])

  @@index([billingId])
  @@map("payments")
}

model Receivable {
  id          String   @id @default(uuid())
  billingId   String   @unique @map("billing_id")
  studentId   String   @map("student_id")
  amount      Float    // Outstanding amount
  dueDate     DateTime @map("due_date")
  isOverdue   Boolean  @default(false) @map("is_overdue")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  billing Billing @relation(fields: [billingId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([isOverdue])
  @@map("receivables")
}

// ========================================
// EXPENSES
// ========================================

model Expense {
  id            String        @id @default(uuid())
  title         String
  description   String?
  category      String
  amount        Float
  status        ExpenseStatus @default(DRAFT)
  requestedBy   String        @map("requested_by") // user id
  submittedAt   DateTime?     @map("submitted_at")
  paidAt        DateTime?     @map("paid_at")
  closedAt      DateTime?     @map("closed_at")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  approvals   ExpenseApproval[]
  attachments ExpenseAttachment[]

  @@index([status])
  @@index([requestedBy])
  @@map("expenses")
}

model ExpenseApproval {
  id         String   @id @default(uuid())
  expenseId  String   @map("expense_id")
  approvedBy String   @map("approved_by") // user id
  action     String   // 'approved' or 'rejected'
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_approvals")
}

model ExpenseAttachment {
  id         String   @id @default(uuid())
  expenseId  String   @map("expense_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("expense_attachments")
}

// ========================================
// NOTIFICATIONS & EMAIL LOGS
// ========================================

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String
  type      String   // 'billing', 'invoice', 'expense', 'system'
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model EmailLog {
  id          String   @id @default(uuid())
  recipient   String
  subject     String
  body        String   @db.Text
  status      String   // 'sent', 'failed'
  failReason  String?  @map("fail_reason")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([recipient])
  @@index([createdAt])
  @@map("email_logs")
}

// ========================================
// ORGANIZATION SETTINGS
// ========================================

model OrganizationSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organization_settings")
}
